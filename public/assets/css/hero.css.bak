.industrial-grid .hero-mini-features { display: none !important; }

/* Uniform padding and flush image alignment for Product pages */
#hero-slider.industrial-grid .hero-grid {
  padding: 60px !important;
  gap: 30px !important;
  align-items: stretch !important;
}

#hero-slider.industrial-grid .hero-text {
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
  align-items: flex-start;
}

#hero-slider.industrial-grid .hero-image-col {
  align-items: stretch !important;
  justify-content: flex-end;
}

#hero-slider.industrial-grid .hero-image-panel {
  height: 100% !important;
  width: 100% !important;
  display: block !important;
}

#hero-slider.industrial-grid .hero-image-panel img {
  height: 100% !important;
  width: 100% !important;
  object-fit: cover !important;
  display: block !important;
}
